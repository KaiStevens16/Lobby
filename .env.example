# Supabase (required for production check-ins)
# Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Project Settings → API → secret key (server-only; never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your-key-here

# Optional: publishable key (not used by this app today)
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key-here
